              }
            ]
          }
          method: "GET"
          orig: "/{width}/{height}"
          parts: [
            "{width}"
            "{height}"
          ]
          select: {
            exist: [
              "blur"
              "grayscale"
              "height"
              "random"
              "width"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



